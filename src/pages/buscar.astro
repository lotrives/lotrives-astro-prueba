---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Buscar | Lotrives"
			description="Buscar en Lotrives."
		/>
	
<style is:global>
	.page {
		max-width: 700px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}
	h1 {
		margin: 0 0 2rem;
		font-size: 2.5rem;
		line-height: 1;
	}
	.b-card {
		border: 1px solid #e0e0e0;
		border-radius: 4px;
		padding: 1rem 1.2rem;
		margin-bottom: 0.8rem;
	}
	.b-card:hover { border-color: #aaa; }
	.b-card-header {
		display: flex;
		align-items: baseline;
		gap: 0.5em;
		margin-bottom: 0.25rem;
	}
	.b-card-header a {
		font-size: 1.05rem;
		font-weight: 600;
		color: #3273dc;
		text-decoration: none;
	}
	.b-card-header a:hover { text-decoration: underline; }
	.b-type {
		font-size: 0.7em;
		color: #fff;
		background: #888;
		border-radius: 3px;
		padding: 1px 6px;
		white-space: nowrap;
	}
	.b-date {
		font-size: 0.75rem;
		color: #aaa;
		margin-bottom: 0.5rem;
	}
	.b-excerpt {
		font-size: 0.875rem;
		color: #555;
		line-height: 1.55;
		margin-bottom: 0.6rem;
	}
	.b-excerpt mark {
		background: #ffeaa0;
		border-radius: 2px;
		padding: 0 2px;
	}
	.b-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin-top: 0.25rem;
	}
	.b-tag {
		font-size: 0.72rem;
		color: #555;
		background: #f0f0f0;
		border-radius: 3px;
		padding: 2px 7px;
		white-space: nowrap;
	}
	.b-tag mark {
		background: #ffeaa0;
		border-radius: 2px;
		padding: 0 1px;
	}
	.b-nada { font-style: italic; color: #888; }
</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page">
				<h1>Buscar</h1>

				<input type="search" id="buscador-q" placeholder="Busca títulos, textos, etiquetas…" autocomplete="off" disabled style="width:100%;max-width:480px;padding:0.75rem 1rem;font-size:1rem;box-sizing:border-box;margin-top:1rem;">

				<div id="buscador-status" style="font-size:0.8rem;color:#888;margin:0.75rem 0 1rem;min-height:1.2em;"></div>
				<div id="buscador-results"></div>
			</section>
		</main>
		<Footer />

		<script>
		(function () {
		  var posts = [];
		  var input   = document.getElementById('buscador-q');
		  var status  = document.getElementById('buscador-status');
		  var results = document.getElementById('buscador-results');

		  function esc(str) {
		    return (str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
		  }

		  function normalize(str) {
		    if (!str) return '';
		    return str
		      .replace(/[łŁ]/g, 'l')
		      .replace(/[ąĄ]/g, 'a')
		      .replace(/[ęĘ]/g, 'e')
		      .replace(/[ěĚ]/g, 'e')
		      .replace(/[śŚšŠ]/g, 's')
		      .replace(/[źŹżŻžŽ]/g, 'z')
		      .replace(/[ćĆčČ]/g, 'c')
		      .replace(/[ńŃ]/g, 'n')
		      .replace(/[řŘ]/g, 'r')
		      .replace(/[ůŮ]/g, 'u')
		      .replace(/[ýÝ]/g, 'y')
		      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
		      .toLowerCase();
		  }

		  function queryToRegex(q) {
		    var map = {
		      'a': '[aąáàâä]',
		      'e': '[eęěéèêë]',
		      'i': '[iíîï]',
		      'o': '[oóôö]',
		      'u': '[uůúûü]',
		      'n': '[nń]',
		      'l': '[lł]',
		      's': '[sśš]',
		      'z': '[zźżž]',
		      'c': '[cćč]',
		      'r': '[rř]',
		      'y': '[yý]'
		    };
		    return q.split('').map(function(ch) {
		      var low = ch.toLowerCase();
		      var pat = map[low] || ch.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		      return pat;
		    }).join('');
		  }

		  function match(p, qn) {
		    return normalize(p.title).indexOf(qn) !== -1 ||
		           normalize(p.content).indexOf(qn) !== -1 ||
		           normalize(p.excerpt).indexOf(qn) !== -1 ||
		           normalize(p.tags).indexOf(qn) !== -1;
		  }

		  function hl(text, q) {
		    if (!q || !text) return esc(text||'');
		    var re = new RegExp('(' + queryToRegex(q) + ')', 'gi');
		    return esc(text).replace(re, function(m) {
		      return '<mark>' + m + '</mark>';
		    });
		  }

		  function excerpt(text, qn) {
		    var src = text || '';
		    var srcNorm = normalize(src);
		    var idx = qn ? srcNorm.indexOf(qn) : -1;
		    var s = idx > 60 ? idx - 60 : 0;
		    var chunk = src.slice(s, s + 220);
		    if (s > 0) chunk = '…' + chunk;
		    if (s + 220 < src.length) chunk += '…';
		    return chunk;
		  }

		  function fmtDate(raw) {
		    if (!raw) return '';
		    var d = new Date(raw);
		    return isNaN(d) ? raw : d.toLocaleDateString('es-ES', { year:'numeric', month:'long', day:'numeric' });
		  }

		  function renderCards(matched, q, qn) {
		    return matched.map(function(p) {
		      var typeTag = (p.type === 'nota' || p.type === 'página')
		        ? '<span class="b-type">' + esc(p.type) + '</span>'
		        : '';
		      var tagsHtml = p.tags
		        ? p.tags.split(', ').map(function(t) {
		            return '<span class="b-tag">' + hl(t.trim(), q) + '</span>';
		          }).join('')
		        : '';
		      return '<div class="b-card">' +
		        '<div class="b-card-header"><a href="' + esc(p.url) + '">' + hl(p.title||'', q) + '</a>' + (typeTag ? ' ' + typeTag : '') + '</div>' +
		        (p.date ? '<div class="b-date">' + fmtDate(p.date) + '</div>' : '') +
		        '<div class="b-excerpt">' + hl(excerpt(p.content||p.excerpt||'', qn), q) + '</div>' +
		        (tagsHtml ? '<div class="b-tags">' + tagsHtml + '</div>' : '') +
		        '</div>';
		    }).join('');
		  }

		  function search(query) {
		    var q = query.trim();
		    if (!q) {
		      results.innerHTML = '';
		      status.innerHTML = posts.length + ' entradas indexadas';
		      return;
		    }

		    var qn = normalize(q);
		    var matched = posts.filter(function(p) { return match(p, qn); });
		    var n = matched.length;

		    if (n > 0) {
		      status.innerHTML = n + ' resultado' + (n !== 1 ? 's' : '') + ' para "<strong>' + esc(q) + '</strong>"';
		      results.innerHTML = renderCards(matched, q, qn);
		    } else {
		      status.innerHTML = '0 resultados para "<strong>' + esc(q) + '</strong>"';
		      results.innerHTML = '<p class="b-nada">No se encontró nada.</p>';
		    }
		  }

		  fetch('/search.json')
		    .then(function(r) { return r.json(); })
		    .then(function(data) {
		      posts = data;
		      input.disabled = false;
		      input.focus();
		      status.length + ' entradas indexadas';
		      status.innerHTML = posts.length + ' entradas indexadas';
		    })
		    .catch(function() {
		      status.innerHTML = 'Error al cargar el índice.';
		    });

		  var timer;
		  input.addEventListener('input', function(e) {
		    clearTimeout(timer);
		    timer = setTimeout(function() { search(e.target.value); }, 250);
		  });
		})();
		</script>
	</body>
</html>

