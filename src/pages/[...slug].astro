---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const sorted = posts
		.filter((p) => !p.data.draft)
		.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

	const postUrl = (p: CollectionEntry<'blog'>) => {
		const pid = p.id.replace(/\.md$/, '');
		const [y, m, d, ...r] = pid.split('-');
		return `/${y}/${m}/${d}/${r.join('-')}/`;
	};

	const truncate = (str: string, max: number) =>
		str.length > max ? str.slice(0, max).trimEnd() + '…' : str;

	return sorted.map((post, index) => {
		const id = post.id.replace(/\.md$/, '');
		const [year, month, day, ...rest] = id.split('-');

		const newer = index > 0 ? sorted[index - 1] : null;
		const older = index < sorted.length - 1 ? sorted[index + 1] : null;

		return {
			params: { slug: `${year}/${month}/${day}/${rest.join('-')}` },
			props: {
				post,
				prev: newer ? { title: truncate(newer.data.title, 70), url: postUrl(newer) } : null,
				next: older ? { title: truncate(older.data.title, 70), url: postUrl(older) } : null,
			},
		};
	});
}

type Props = {
	post: CollectionEntry<'blog'>;
	prev: { title: string; url: string } | null;
	next: { title: string; url: string } | null;
};

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prev={prev} next={next}>
	<Content />
</BlogPost>
