---
import { getEntry, render } from 'astro:content';
import Page from '../layouts/Page.astro';

const entry = await getEntry('pages', 'aceprensa');
const { Content } = await render(entry);
---
<Page title={entry.data.title} description={entry.data.description} wide>
	<h1>Aceprensa</h1>
<Content />
</Page>
