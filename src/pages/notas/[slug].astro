---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((note) => ({
		params: { slug: note.id.replace(/\.md$/, '') },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const slugify = (text) =>
	text.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const pubDate = new Date(note.data.pubDate);
const description = note.data.description ?? note.body.replace(/[#*`>\-]/g, '').trim().slice(0, 160);

const _allPosts = await getCollection('blog');
const _allNotes = await getCollection('notes');
const _allPages = await getCollection('pages');
const _tagCount = new Map();
for (const items of [_allPosts, _allNotes, _allPages]) {
for (const item of items) {
for (const t of (item.data.tags ?? [])) {
_tagCount.set(t, (_tagCount.get(t) ?? 0) + 1);
}
}
}
const visibleTags = (note.data.tags ?? []).filter(t => (_tagCount.get(t) ?? 0) >= 3);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`${note.data.title} | Lotrives`}
			description={description}
			image={note.data.heroImage}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="notas-wrap">
				<article class="nota">
					{note.data.title && <h1 class="nota-titulo">{note.data.title}</h1>}
					<div class="nota-cuerpo">
						<Content />
					</div>
					
					<p class="nota-fecha"><FormattedDate date={pubDate} /></p>
					{visibleTags.length > 0 && (
						<div class="nota-tags">
							{visibleTags.map((tag, i) => (
								<>
									{i > 0 && ' · '}
									<a href={`${base}/etiquetas/#tag-${slugify(tag)}`} class="nota-tag">{tag}</a>
								</>
							))}
						</div>
					)}
				</article>
				<p class="volver"><a href="/notas">← Todas las notas</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.notas-wrap { max-width: 700px; margin: 0 auto; }
	.nota-titulo {
		font-size: 1.35rem;
		line-height: 1.25;
		margin: 0 0 0.9rem;
		font-weight: 600;
	}
	.nota-cuerpo { font-size: inherit; line-height: 1.7; }
	.nota-imagen { margin: 0.8em 0; max-width: 100%; border-radius: 8px; }
	.nota-fecha { margin-top: 1em; font-size: 0.8em; color: rgb(var(--gray)); letter-spacing: 0.03em; }
	.nota-tags { margin-top: 0.4em; font-size: 0.85em; color: rgb(var(--gray)); }
	.nota-tag { color: rgb(var(--gray)); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: rgb(var(--gray-light)); }
	.nota-tag:hover { color: var(--accent); }
	.volver { margin-top: 2rem; font-size: 0.9em; }
</style>

<script>
  document.querySelectorAll('.nota-cuerpo a[href]').forEach((a) => {
    const href = a.getAttribute('href') ?? '';
    if (/^https?:\/\//.test(href) && !href.startsWith('https://lotrives.com')) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
    }
  });

(function () {
  const toast = document.createElement('div');
  toast.id = 'copy-toast';
  toast.textContent = 'Enlace copiado';
  document.body.appendChild(toast);
  let timer;
  document.querySelectorAll('.heading-anchor').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const id = a.getAttribute('href');
      const url = window.location.origin + window.location.pathname + id;
      navigator.clipboard.writeText(url).catch(() => {});
      clearTimeout(timer);
      toast.classList.add('visible');
      timer = setTimeout(() => toast.classList.remove('visible'), 1800);
      history.pushState(null, '', id);
      document.querySelector(id)?.scrollIntoView({ behavior: 'smooth' });
    });
  });
})();
</script>
