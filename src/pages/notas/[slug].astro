---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const notes = (await getCollection('notes')).filter(n => !n.data.draft);
	const sorted = notes.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
	return sorted.map((note, i) => ({
		params: { slug: note.id.replace(/\.md$/, '') },
		props: {
			note,
			next: sorted[i + 1] ? { title: sorted[i + 1].data.title, url: `/notas/${sorted[i + 1].id.replace(/\.md$/, '')}/` } : null,
			prev: sorted[i - 1] ? { title: sorted[i - 1].data.title, url: `/notas/${sorted[i - 1].id.replace(/\.md$/, '')}/` } : null,
		},
	}));
}

const { note, prev, next } = Astro.props;
const { Content } = await render(note);

const pubDate = new Date(note.data.pubDate);
const description = note.data.description ?? note.body.replace(/[#*`>\-]/g, '').trim().slice(0, 160);
---

<BlogPost
	title={note.data.title}
	description={description}
	pubDate={pubDate}
	updatedDate={note.data.updatedDate}
	heroImage={note.data.heroImage}
	tags={note.data.tags}
	author={note.data.author}
	prev={prev}
	next={next}
>
	<Content />
</BlogPost>
