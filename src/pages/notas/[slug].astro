---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((note) => ({
		params: { slug: note.id.replace(/\.md$/, '') },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const formatDateTime = (date) =>
	new Intl.DateTimeFormat('es-ES', {
		day: '2-digit',
		month: '2-digit',
		year: 'numeric',
		hour: '2-digit',
		minute: '2-digit',
		timeZone: 'Europe/Madrid',
	}).format(new Date(date));

const excerpt = note.body.replace(/[#*`>\-]/g, '').trim().slice(0, 120);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`Nota ${formatDateTime(note.data.pubDate)} | Lotrives`}
			description={excerpt}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="notas-wrap">
				<article class="nota">
					<div class="nota-cuerpo">
						<Content />
					</div>
					{note.data.image && <img src={note.data.image} alt="" class="nota-imagen" />}
					<p class="nota-fecha">{formatDateTime(note.data.pubDate)}</p>
					{note.data.tags && note.data.tags.length > 0 && (
						<div class="nota-tags">
							{note.data.tags.map((tag) => (
								<span class="nota-tag">{tag}</span>
							))}
						</div>
					)}
				</article>
				<p class="volver"><a href="/notas">← Todas las notas</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.notas-wrap { max-width: 600px; margin: 0 auto; }
	.nota-cuerpo { font-size: inherit; line-height: 1.7; }
	.nota-imagen { margin: 0.8em 0; max-width: 100%; border-radius: 8px; }
	.nota-fecha { margin-top: 1em; font-size: 0.8em; color: rgb(var(--gray)); letter-spacing: 0.03em; }
	.nota-tags { margin-top: 0.4em; }
	.nota-tag {
		display: inline-block;
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin-right: 0.4em;
	}
	.nota-tag::before { content: '#'; }
	.volver { margin-top: 2rem; font-size: 0.9em; }
</style>
