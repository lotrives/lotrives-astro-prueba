---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const slugify = (text) =>
	text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

const notes = await getCollection('notes');

const _allPosts = await getCollection('blog');
const _allPages = await getCollection('pages');
const _tagCount = new Map();
for (const items of [_allPosts, notes, _allPages]) {
for (const item of items) {
for (const t of (item.data.tags ?? [])) {
_tagCount.set(t, (_tagCount.get(t) ?? 0) + 1);
}
}
}

const sortedNotes = notes.sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const renderedNotes = await Promise.all(
	sortedNotes.map(async (note) => {
		const { Content } = await render(note);
		return { note, Content };
	})
);

const formatDateTime = (input) => {
	const str = input instanceof Date ? input.toISOString() : input;
	const parts = str.split('T');
	const [y, m, d] = parts[0].split('-');
	const [h, min] = (parts[1] || '00:00').split(':');
	return `${d}/${m}/${y}, ${h}:${min}`;
};

const noteSlug = (note) => note.id.replace(/\.md$/, '');
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Notas | Lotrives"
			description="Apuntes breves y observaciones."
		/>
		<link rel="alternate" type="application/rss+xml" title="Notas — Lotrives" href="/notas-feed.xml" />
	</head>
	<body>
		<Header />
		<main>
			<section class="notas-wrap">
				<h1>Notas</h1>

				{renderedNotes.map(({ note, Content, visibleTags }) => (
					<article class="nota">
						<h2 class="nota-titulo">
							<a href={`/notas/${noteSlug(note)}`}>{note.data.title}</a>
						</h2>
						<div class="nota-cuerpo">
							<Content />
						</div>
						{note.data.image && <img src={note.data.image} alt="" class="nota-imagen" />}
						<p class="nota-fecha">
							{formatDateTime(note.data.pubDate)}
						</p>
						{visibleTags.length > 0 && (
							<div class="nota-tags">
								{visibleTags.map((tag) => (
									<a href={`${base}/etiquetas/#tag-${slugify(tag)}`} class="nota-tag">{tag}</a>
								))}
							</div>
						)}
						<hr class="nota-separador" />
					</article>
				))}

				<p class="rss-pie"><a href="/notas-feed.xml">Feed RSS de notas</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.notas-wrap {
		max-width: 700px;
		margin: 0 auto;
	}
	h1 { margin: 0 0 2rem; font-size: 2.5rem; line-height: 1; }
	.nota { margin-bottom: 0; }
	.nota-titulo {
		margin: 0 0 0.6rem;
		font-size: 1.15em;
		line-height: 1.25;
	}
	.nota-titulo a {
		color: rgb(var(--black));
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: rgb(var(--gray-light));
	}
	.nota-titulo a:hover {
		color: var(--accent);
	}
	.nota-cuerpo { font-size: inherit; line-height: 1.7; }
	.nota-imagen { margin: 0.8em 0; max-width: 100%; border-radius: 8px; }
	.nota-fecha {
		margin: 0.6em 0 0;
		font-size: 0.8em;
		color: rgb(var(--gray));
		letter-spacing: 0.03em;
	}
	.nota-tags { margin-top: 0.4em; }
	.nota-tag {
		display: inline-block;
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin-right: 0.4em;
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: rgb(var(--gray-light));
	}
	.nota-tag:hover { color: var(--accent); }

	.nota-separador { margin: 1.5rem 0; }
	.rss-pie { margin-top: 1rem; font-size: 0.8em; color: rgb(var(--gray)); }
</style>
<script>
document.querySelectorAll(".nota-cuerpo a[href]").forEach((a) => {
  const href = a.getAttribute("href") ?? "";
  if (/^https?:\/\//.test(href) && !href.startsWith("https://lotrives.com")) {
    a.setAttribute("target", "_blank");
    a.setAttribute("rel", "noopener noreferrer");
  }
});
</script>
