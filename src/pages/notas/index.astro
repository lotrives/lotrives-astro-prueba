---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingTOC from '../../components/FloatingTOC.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const notes = (await getCollection('notes'))
	.filter((note) => !note.data.draft)
	.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const notesByYear = notes.reduce((groups, note) => {
	const year = new Date(note.data.pubDate).getFullYear();
	if (!groups[year]) groups[year] = [];
	groups[year].push(note);
	return groups;
}, {});

const years = Object.keys(notesByYear).sort((a, b) => Number(b) - Number(a));

const formatDate = (input) => {
	const str = input instanceof Date ? input.toISOString() : input;
	const [datePart, timePart] = str.split('T');
	const [y, m, d] = datePart.split('-');
	const [h, min] = (timePart || '00:00').split(':');
	return `${d}/${m}/${y}, ${h}:${min}`;
};

const noteSlug = (note) => note.id.replace(/\.md$/, '');
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Notas | Lotrives"
			description="Apuntes breves y observaciones."
		/>
		<link rel="alternate" type="application/rss+xml" title="Notas — Lotrives" href="/notas-feed.xml" />
	</head>
	<body>
		<Header />
		<main>
			<section class="page">
				<h1>Notas</h1>

				{years.map((year) => (
					<section>
						<h2 class="notas-anio" id={`year-${year}`}>{year}</h2>
						<ul class="notas-lista">
							{notesByYear[year].map((note) => (
								<li>
									<a href={`${base}/notas/${noteSlug(note)}/`}>{note.data.title}</a>
									<span class="notas-fecha">{formatDate(note.data.pubDate)}</span>
								</li>
							))}
						</ul>
					</section>
				))}

				<p class="rss-pie"><a href="/notas-feed.xml">Feed RSS de notas</a></p>
			</section>
		</main>
		<FloatingTOC />
		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: 700px;
		margin: 0 auto;
		padding: 1.5rem 1.5rem;
	}

	h1 {
		margin: 0 0 2rem;
		font-size: 2.5rem;
		line-height: 1;
	}

	.notas-anio {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
		font-size: 1.75rem;
		line-height: 1.2;
	}

	.notas-lista {
		list-style: none;
		margin-left: 0;
		padding-left: 0;
	}

	.notas-lista li {
		margin-bottom: 0.5em;
		font-size: 1.05rem;
		line-height: 1.6;
	}

	.notas-fecha {
		font-size: 0.75em;
		color: #999;
		margin-left: 0.4em;
		letter-spacing: 0.04em;
	}

	a {
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
	}

	.rss-pie {
		margin-top: 2rem;
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
</style>
