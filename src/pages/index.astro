---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);

const notes = (await getCollection('notes')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
).slice(0, 4);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const postUrl = (post) => `${base}/${post.id.replace(/\.md$/, '').replace(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/, '$1/$2/$3/$4')}/`;
const noteSlug = (note) => note.id.replace(/\.md$/, '');
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .intro {
        margin-top: 0;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        font-size: 1.25em;
        font-style: normal;
        font-weight: 400;
        color: rgb(var(--gray));
        line-height: 1.5;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      @media (max-width: 720px) {
        .intro {
          font-size: 1.1em;
        }
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-list li {
        margin-bottom: 1.8em;
      }
      .post-list .date {
        display: block;
        font-size: 0.8em;
        color: rgb(var(--gray));
        margin-bottom: 0.1em;
      }
      .post-list a {
        font-size: 1em;
        color: rgb(var(--gray-dark));
        text-decoration: none;
      }
      .post-list a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--accent);
      }
      .post-list .excerpt {
        margin: 0.4em 0 0;
        font-size: 0.92em;
        color: rgb(var(--gray));
        line-height: 1.5;
      }
      .ver-todos a {
        color: rgb(var(--gray));
        text-decoration: none;
      }
      .ver-todos a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--accent);
      }

      /* Bloque de notas recientes */
      .seccion-titulo {
        font-size: 0.75em;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgb(var(--gray));
        margin: 0 0 1.2rem;
      }
      .notas-recientes {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .notas-recientes li {
        margin-bottom: 1.8em;
      }
      .notas-recientes .date {
        display: block;
        font-size: 0.8em;
        color: rgb(var(--gray));
        margin-bottom: 0.1em;
      }
      .notas-recientes a {
        font-size: 1em;
        color: rgb(var(--gray-dark));
        text-decoration: none;
        line-height: 1.4;
      }
      .notas-recientes a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--accent);
      }
      .bloque-notas {
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgb(var(--gray-light));
      }
    </style>
  </head>
  <body>
    <Header />
    <main style="max-width: 700px; margin: 0 auto; padding: 1.5rem;">
      <p class="intro">
        Artículos y notas de trabajo de José Manuel Grau Navarro, donde ofrece su mirada al mundo que somos para comprender mejor a las personas, la sociedad y la Iglesia.
      </p>

      <p class="seccion-titulo">Últimos artículos</p>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <span class="date">{post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <a href={postUrl(post)}>{post.data.title}</a>
            {post.data.description && (
              <p class="excerpt">{post.data.description}</p>
            )}
          </li>
        ))}
      </ul>
      <p class="ver-todos"><a href={`${base}/archivo/`}>Ver todos los artículos →</a></p>

      <div class="bloque-notas">
        <p class="seccion-titulo">Notas recientes</p>
        <ul class="notas-recientes">
          {notes.map((note) => (
            <li>
              <span class="date">{new Date(note.data.pubDate).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <a href={`${base}/notas/${noteSlug(note)}/`}>{note.data.title}</a>
            </li>
          ))}
        </ul>
        <p class="ver-todos" style="margin-top: 1rem;"><a href={`${base}/notas/`}>Ver todas las notas →</a></p>
      </div>
    </main>
    <Footer />
  </body>
</html>
