---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Otras publicaciones | Lotrives"
			description="Artículos y colaboraciones de José Manuel Grau Navarro en otros medios, firmados en distintas etapas como José Grau o José Manuel Navarro."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page">
				<h1>Otras publicaciones</h1>

				<p>
					Artículos y colaboraciones de <strong>José Manuel Grau Navarro</strong> publicados en otros medios.
					Hasta 2013 firmó como <strong>José Grau</strong> en la mayor parte de ellos; en <em>La Vanguardia</em>,
					como <strong>José Manuel Navarro</strong>. Desde 2013 utiliza su nombre completo.
				</p>

				<hr />

				<h3>Medios con archivo propio</h3>

				<p>
					<a href="/lotrives-astro-prueba/abc/">ABC</a> ·
					<a href="/lotrives-astro-prueba/aceprensa/">Aceprensa</a> ·
					<a href="/lotrives-astro-prueba/la-vanguardia/">La Vanguardia</a>
				</p>

				<h3>Medios con índice externo</h3>

				<p>
					<a href="https://www.nuevarevista.net/autor/jose-manuel-grau-navarro/" target="_blank" rel="noopener">Nueva Revista ↗</a>
					·
					<a href="https://dialnet.unirioja.es/servlet/autor?codigo=872384" target="_blank" rel="noopener">Dialnet ↗</a>
				</p>

				<h3>Otros medios</h3>

				<p>
					<a href="/lotrives-astro-prueba/otros/">Otros medios</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: 760px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	h1 {
		margin: 0 0 2rem;
		font-size: clamp(2.5rem, 8vw, 4rem);
		line-height: 1;
	}

	h3 {
		margin: 2rem 0 0.75rem;
		font-size: 1.35rem;
		line-height: 1.35;
	}

	p {
		margin: 0 0 1.4rem;
		font-size: 1.05rem;
		line-height: 1.75;
	}

	hr {
		margin: 2.25rem 0;
		border: 0;
		border-top: 1px solid #ddd;
	}

	a {
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
	}
</style>
