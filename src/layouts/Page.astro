---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FloatingTOC from '../components/FloatingTOC.astro';

const { title, description, wide } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`${title} | Lotrives`}
			description={description || ''}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class={wide ? 'page wide' : 'page'}>
				<slot />
			</section>
		</main>
		<FloatingTOC />
		<Footer />
		<script>
		document.querySelectorAll("a[href]").forEach((a) => {
		  const href = a.getAttribute("href") ?? "";
		  if (/^https?:\/\//.test(href) && !href.startsWith("https://lotrives.com")) {
		    a.setAttribute("target", "_blank");
		    a.setAttribute("rel", "noopener noreferrer");
		  }
		});

		(function () {
		  const toast = document.createElement('div');
		  toast.id = 'copy-toast';
		  toast.textContent = 'Enlace copiado';
		  document.body.appendChild(toast);
		  let timer;

		  function showToast() {
		    clearTimeout(timer);
		    toast.classList.add('visible');
		    timer = setTimeout(() => toast.classList.remove('visible'), 1800);
		  }

		  function attachCopy(el, id) {
		    el.addEventListener('click', (e) => {
		      e.preventDefault();
		      const url = window.location.origin + window.location.pathname + id;
		      navigator.clipboard.writeText(url).catch(() => {});
		      showToast();
		      history.pushState(null, '', id);
		      document.querySelector(id)?.scrollIntoView({ behavior: 'smooth' });
		    });
		  }

		  // Headings procesados por rehype-autolink-headings
		  document.querySelectorAll('.heading-anchor').forEach((a) => {
		    attachCopy(a, a.getAttribute('href'));
		  });

		  // Headings HTML crudos con id pero sin .heading-anchor
		  document.querySelectorAll('h2[id], h3[id]').forEach((h) => {
		    if (h.querySelector('.heading-anchor')) return;
		    const id = '#' + h.id;
		    const a = document.createElement('a');
		    a.className = 'heading-anchor';
		    a.href = id;
		    a.setAttribute('aria-hidden', 'true');
		    a.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
		    h.prepend(a);
		    attachCopy(a, id);
		  });
		})();
		</script>
	</body>
</html>

<style>
	.page {
		max-width: 700px;
		margin: 0 auto;
		padding: 1.5rem 1.5rem;
	}
	.page.wide {
		max-width: 820px;
	}
</style>
