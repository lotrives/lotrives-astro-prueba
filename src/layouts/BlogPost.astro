---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prev?: { title: string; url: string } | null;
	next?: { title: string; url: string } | null;
};

const { title, description, pubDate, updatedDate, heroImage, tags, prev, next } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const slugify = (text: string) =>
	text.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const truncate = (str: string, max: number) =>
	str.length > max ? str.slice(0, max).trimEnd() + '…' : str;
---

<html lang="es">
	<head>
		<BaseHead title={`${title} | Lotrives`} description={description} image={heroImage} />
		<style>
	main {
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0;
		padding-top: 0.5em;
	}
	.prose {
		width: 600px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
		color: rgb(var(--gray-dark));
	}
	.title {
		margin-bottom: 1em;
		padding: 0;
		text-align: left;
		line-height: 1;
	}
	.title h1 {
		margin: 0 0 0.4em 0;
		font-size: 2rem;
		font-weight: 600;
		line-height: 1.2;
	}
	.date {
		margin-top: 0.4em;
		margin-bottom: 0.5em;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
	.last-updated-on {
		font-style: italic;
	}
	.tags {
		margin-top: 2em;
		padding-top: 1em;
		border-top: 1px solid rgb(var(--gray-light));
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.tags a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.tags a:hover {
		color: var(--accent);
	}
	.nav-posts {
		margin-top: 2em;
		padding-top: 1em;
		border-top: 1px solid rgb(var(--gray-light));
		display: flex;
		justify-content: space-between;
		gap: 1em;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.nav-posts a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.nav-posts a:hover {
		color: var(--accent);
	}
	.nav-prev { text-align: left; }
	.nav-next { text-align: right; margin-left: auto; }
</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<div class="last-updated-on">
									Actualizado el <FormattedDate date={updatedDate} />
								</div>
							)}
						</div>
						<hr />
					</div>
					<slot />
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag, i) => (
								<>
									{i > 0 && ' · '}
									<a href={`${base}/etiquetas/#tag-${slugify(tag)}`}>{tag}</a>
								</>
							))}
						</div>
					)}
					<nav class="nav-posts">
						{prev && (
							<span class="nav-prev">
								<a href={prev.url}>← {truncate(prev.title, 50)}</a>
							</span>
						)}
						{next && (
							<span class="nav-next">
								<a href={next.url}>{truncate(next.title, 50)} →</a>
							</span>
						)}
					</nav>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
